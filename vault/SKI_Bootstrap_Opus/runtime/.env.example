# ═══════════════════════════════════════════════════════════════
# SKI Runtime — Environment Variables
# Kopiere diese Datei nach .env und passe die Werte an:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# --- Netzwerk ---
SKI_HOST_IP=192.168.178.90

# --- LM Studio (laeuft auf dem Windows Host) ---
SKI_LM_STUDIO_BASE_URL=http://192.168.178.90:1234/v1

# --- Telegram Bot 1 (OpenClaw) ---
SKI_TELEGRAM_BOT_TOKEN=your-token-here

# --- Telegram Bot 2 (OpenClaw-2) ---
SKI_TELEGRAM_BOT_TOKEN_2=your-second-token-here
SKI_BOT_NAME=OpenClaw-2

# --- Hermes Agent ---
SKI_HERMES_DEFAULT_PROFILE=tiferet-beta

# Model Pinning (substring match, LM Studio IDs enthalten Quant-Suffixe)
# Primaer: Hermes 4.3-36B (NousResearch/Hermes-4.3-36B-GGUF)
# Fallback: Hermes 3-Llama-3.1-8B (NousResearch/Hermes-3-Llama-3.1-8B-GGUF)
SKI_HERMES_MODEL=hermes-4.3-36b
SKI_HERMES_MODEL_FALLBACK=hermes-3-llama-3.1-8b

# Tool-Calling Support (true/false) — injiziert Standard-Toolset fuer Vault-Zugriff
SKI_HERMES_TOOL_CALLING=true

# Max Tool-Rounds pro Request (verhindert Infinite Loops)
SKI_HERMES_MAX_TOOL_ROUNDS=3

# Memory/Session History Laenge (Messages die beim Reload zurueckgeladen werden)
SKI_HERMES_HISTORY_LIMIT=20
