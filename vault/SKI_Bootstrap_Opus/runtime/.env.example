# ═══════════════════════════════════════════════════════════════
# SKI Runtime — Environment Variables
# Kopiere diese Datei nach .env und passe die Werte an:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# --- Netzwerk ---
SKI_HOST_IP=192.168.178.90

# --- LM Studio (läuft auf dem Windows Host) ---
SKI_LM_STUDIO_BASE_URL=http://192.168.178.90:1234/v1

# --- Telegram Bot (OpenClaw) ---
SKI_TELEGRAM_BOT_TOKEN=your-token-here

# --- Hermes Agent ---
SKI_HERMES_DEFAULT_PROFILE=tiferet-beta
