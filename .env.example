# SKI — Sephirotische Kernintelligenz
# Environment Variables Template
# Copy to .env and fill in your values

# ── Host (Windows Server 2025) ──
SKI_HOST_IP=192.168.178.90
SKI_LM_STUDIO_PORT=1234
SKI_LM_STUDIO_BASE_URL=http://192.168.178.90:1234/v1

# ── VM (Ubuntu 24.04) ──
SKI_VM_IP=192.168.178.124

# ── Models (Bonsai Prism 8B) ──
# Two instances: one Symbolect-trained, one normal
SKI_MODEL_NORMAL=bonsai-prism-8b
SKI_MODEL_SYMBOLECT=bonsai-prism-8b-symbolect
SKI_MODEL_EMBEDDING=nomic-embed-text

# ── Vault (Obsidian) ──
SKI_VAULT_MOUNT=/mnt/28bots_core
SKI_VAULT_SMB_SHARE=//192.168.178.90/SKI-Vault-Root
SKI_VAULT_SMB_USER=skiuser
# SKI_VAULT_SMB_PASS=  # Use /etc/smbcredentials instead

# ── Docker Ports ──
SKI_DEERFLOW_PORT=2026
SKI_DEERFLOW_FRONTEND_PORT=3100
SKI_DEERFLOW_LANGGRAPH_PORT=2024
SKI_DEERFLOW_GATEWAY_PORT=8001
SKI_OPENCLAW_PORT=3000
SKI_AGENT_ZERO_PORT=8080
SKI_MILVUS_PORT=19530

# ── Telegram ──
SKI_TELEGRAM_BOT_TOKEN=your-bot-token-here
SKI_TELEGRAM_BOT_USERNAME=MegamarphBot

# ── Hermes (v0.7.0) ──
SKI_HERMES_DEFAULT_PROFILE=tiferet-beta
SKI_HERMES_MEMORY_PROVIDER=built-in
# Set to "milvus" to use Milvus as pluggable memory backend
# SKI_HERMES_MEMORY_PROVIDER=milvus
SKI_HERMES_CAMOFOX_PORT=9377
